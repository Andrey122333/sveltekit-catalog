{
  "name": "sveltekit-catalog",
  "version": "1.0.0",
  "description": "Интернет-каталог 'Код и Кофе' на SvelteKit",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "start": "cross-env PORT=3000 node build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "dependencies": {
    "@sveltejs/adapter-node": "^5.5.4"
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^25.8.0",
    "cross-env": "^7.0.3",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.8",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
